---
import { getCollection, render } from 'astro:content';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import { Card, CardHeader, CardTitle, CardContent } from '@/components/ui/card';

export async function getStaticPaths() {
  const courses = await getCollection('courses');
  return courses.map(course => ({
    params: { slug: course.id },
    props: { course },
  }));
}

const { course } = Astro.props;
const { Content } = await render(course);

const lessons = await getCollection('lessons');

// Helper to get lesson data from slug
const getLessonData = (lessonSlug) => {
  return lessons.find(l => l.id === lessonSlug);
};
---

<DefaultLayout title={course.data.title} description={course.data.shortDescription || course.data.title}>
  <div class="container mx-auto px-4 pt-28 pb-12 lg:pt-44 lg:pb-32">
    <div class="flex flex-col lg:flex-row gap-12">
      <!-- Course Content -->
      <div class="lg:w-2/3">
        {course.data.coverImage && (
          <div class="w-full h-64 md:h-96 overflow-hidden rounded-xl mb-8">
            <img 
              src={course.data.coverImage} 
              alt={course.data.title} 
              class="w-full h-full object-cover"
            />
          </div>
        )}
        
        <h1 class="text-4xl md:text-5xl font-bold mb-4">{course.data.title}</h1>
        <p class="text-xl text-muted-foreground mb-6">{course.data.shortDescription}</p>
        
        <div class="flex items-center gap-4 mb-8">
          <Badge className="capitalize">{course.data.level}</Badge>
          <span class="text-sm text-muted-foreground">Status: {course.data.status}</span>
        </div>

        <div class="prose prose-lg dark:prose-invert max-w-none mb-12">
          <Content />
        </div>

        {course.data.chapters && course.data.chapters.length > 0 && (
          <div class="mt-12">
            <h2 class="text-3xl font-bold mb-6">Curriculum</h2>
            <div class="flex flex-col gap-6">
              {course.data.chapters.map((chapter, index) => (
                <Card>
                  <CardHeader>
                    <CardTitle className="text-xl">Chapter {index + 1}: {chapter.title}</CardTitle>
                    {chapter.description && <p class="text-muted-foreground">{chapter.description}</p>}
                  </CardHeader>
                  <CardContent>
                    <ul class="flex flex-col gap-3">
                      {chapter.items && chapter.items.map(item => {
                        if (item.discriminant === 'lesson' && item.value.lessonRef) {
                          const lesson = getLessonData(item.value.lessonRef);
                          return lesson ? (
                            <li class="flex justify-between items-center p-3 bg-muted/50 rounded-lg hover:bg-muted transition-colors">
                              <div class="flex items-center gap-3">
                                <Badge variant="secondary" className="uppercase text-xs">{lesson.data.lessonType}</Badge>
                                <a href={`/lessons/${lesson.id}?course=${course.id}`} class="font-medium hover:underline">
                                  {lesson.data.title}
                                </a>
                              </div>
                              {lesson.data.duration && (
                                <span class="text-sm text-muted-foreground">{lesson.data.duration} min</span>
                              )}
                            </li>
                          ) : null;
                        } else if (item.discriminant === 'quiz' && item.value.quizRef) {
                           return (
                             <li class="flex justify-between items-center p-3 bg-muted/50 rounded-lg hover:bg-muted transition-colors border-l-2 border-blue-500">
                                <div class="flex items-center gap-3">
                                  <Badge variant="outline" className="uppercase text-xs bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300">Quiz</Badge>
                                  <a href={`/quizzes/${item.value.quizRef}?course=${course.id}`} class="font-medium hover:underline text-blue-700 dark:text-blue-400">
                                    Interactive Quiz
                                  </a>
                                </div>
                             </li>
                           );
                        } else if (item.discriminant === 'assignment' && item.value.assignmentRef) {
                           return (
                             <li class="flex justify-between items-center p-3 bg-muted/50 rounded-lg hover:bg-muted transition-colors border-l-2 border-purple-500">
                                <div class="flex items-center gap-3">
                                  <Badge variant="outline" className="uppercase text-xs bg-purple-50 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300">Assignment</Badge>
                                  <a href={`/assignments/${item.value.assignmentRef}?course=${course.id}`} class="font-medium hover:underline text-purple-700 dark:text-purple-400">
                                    Take-home Project
                                  </a>
                                </div>
                             </li>
                           );
                        }
                        return null;
                      })}
                    </ul>
                  </CardContent>
                </Card>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Sidebar -->
      <div class="lg:w-1/3">
        <div class="sticky top-24">
          <Card>
            <CardContent className="p-6">
              <h3 class="text-2xl font-bold mb-4">Start Learning</h3>
              <p class="text-muted-foreground mb-6">Enroll now to get full access to all materials, quizzes, and resources.</p>
              <a href="/batches" class="block w-full mb-4">
                <Button size="lg" className="w-full">Enroll in Course</Button>
              </a>
              <a href="/batches" class="text-sm text-center block text-primary hover:underline">View upcoming live batches</a>
            </CardContent>
          </Card>
          
          {course.data.instructor && (
            <Card className="mt-6">
              <CardContent className="p-6">
                <h4 class="font-bold mb-2 text-sm uppercase text-muted-foreground tracking-wider">Instructor</h4>
                <div class="flex items-center gap-4">
                  <a href={`/instructors/${course.data.instructor}`} class="text-lg font-medium hover:underline">
                    View Instructor Profile
                  </a>
                </div>
              </CardContent>
            </Card>
          )}
        </div>
      </div>
    </div>
  </div>
</DefaultLayout>

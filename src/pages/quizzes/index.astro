---
import { getCollection } from 'astro:content';
import DefaultLayout from '@/layouts/DefaultLayout.astro';
import { Card, CardHeader, CardTitle, CardContent } from '@/components/ui/card';

const quizzes = await getCollection('quizzes');
---

<DefaultLayout title="Quizzes" description="Explore all available quizzes">
  <div class="container mx-auto px-4 pt-28 pb-12 lg:pt-44 lg:pb-32 max-w-4xl">
    <div class="mb-12">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">All Quizzes</h1>
      <p class="text-xl text-muted-foreground">Test your knowledge with our collection of interactive quizzes.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {quizzes.map(quiz => (
        <Card className="hover:border-primary transition-colors h-full flex flex-col">
          <CardHeader>
            <CardTitle>
              <a href={`/quizzes/${quiz.id}`} class="hover:underline">
                {quiz.data.title}
              </a>
            </CardTitle>
          </CardHeader>
          <CardContent className="flex-1">
            {quiz.data.description && (
              <p class="text-muted-foreground line-clamp-3">{quiz.data.description}</p>
            )}
            <div class="mt-4 text-sm font-medium text-primary">
              {quiz.data.questions?.length || 0} Questions
            </div>
          </CardContent>
        </Card>
      ))}
    </div>
  </div>
</DefaultLayout>

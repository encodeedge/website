---
import { getCollection } from 'astro:content';

import { Background } from '@/components/background';
import { BlogPosts } from '@/components/blocks/blog-posts';
import { SITE_TITLE, SITE_DESCRIPTION } from '@/consts';
import DefaultLayout from '@/layouts/DefaultLayout.astro';

const blogPosts = await getCollection('blog');

const notebooks = await Astro.glob<any>('/src/pages/notebooks/*.astro');
const notebookPosts = notebooks
  .filter((n) => !n.file.endsWith('index.astro'))
  .map((n) => {
    const frontmatter = n.frontmatter || n;
    const url = n.url || '';
    const slug = url.split('/').filter(Boolean).pop() || '';
    const title = frontmatter.title || slug
      .split('-')
      .map((word: string) => word.charAt(0).toUpperCase() + word.slice(1))
      .join(' ');

    return {
      id: slug,
      slug: `../notebooks/${slug}`,
      collection: 'notebooks',
      data: {
        title,
        description: frontmatter.description || '',
        pubDate: frontmatter.pubDate ? new Date(frontmatter.pubDate) : new Date(0),
        image: frontmatter.image,
        tags: frontmatter.tags || [],
        authorName: frontmatter.authorName || 'Encode Edge',
        authorImage: frontmatter.authorImage,
      }
    };
  });

const posts = [...blogPosts, ...notebookPosts].sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<DefaultLayout title={SITE_TITLE} description={SITE_DESCRIPTION} >
	<Background>
		<div class="py-28 lg:pt-44 lg:pb-32">
		<section>
        <div class="container max-w-5xl space-y-4 text-center">
          <h1 class="text-2xl font-semibold tracking-tight md:text-4xl lg:text-5xl">
            Blogs
          </h1>

          <p class="text-muted-foreground max-w-md leading-snug font-medium lg:mx-auto">
            Explore our blog for insightful articles, personal reflections and
            more.
          </p>
        </div>
      </section>
			<BlogPosts posts={posts} client:only='react' />
		</div>
	</Background>
</DefaultLayout>
